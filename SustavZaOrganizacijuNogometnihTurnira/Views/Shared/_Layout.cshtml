<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Organizacija nogometnih turnira</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SustavZaOrganizacijuNogometnihTurnira.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="site-nav" aria-label="Glavna navigacija">
            <a class="site-brand" asp-area="" asp-controller="Home" asp-action="Index">Tournament Hub</a>
            <ul class="site-menu">
                <li><a asp-area="" asp-controller="Home" asp-action="Index">Početna</a></li>
                <li><a asp-area="" asp-controller="Turnir" asp-action="Index">Turniri</a></li>
                <li><a asp-area="" asp-controller="Ekipa" asp-action="Index">Ekipe</a></li>
                <li><a asp-area="" asp-controller="Igrac" asp-action="Index">Igrači</a></li>
                <li><a asp-area="" asp-controller="Utakmica" asp-action="Index">Utakmice</a></li>
                <li><a asp-area="" asp-controller="PrijavaEkipe" asp-action="Index">Prijave</a></li>
                <li><a asp-area="" asp-controller="Stadion" asp-action="Index">Stadioni</a></li>
                <li><a asp-area="" asp-controller="Sudac" asp-action="Index">Sudci</a></li>
            </ul>
        </nav>
    </header>

    <main class="page-shell" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <span>&copy; 2026 - Sustav za organizaciju nogometnih turnira</span>
        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privatnost</a>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
