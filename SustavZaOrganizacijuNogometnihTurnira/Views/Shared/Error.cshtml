@model ErrorViewModel

@{
    ViewData["Title"] = "Greška";
}

<header class="page-header">
    <div>
        <p class="page-kicker">Sustav</p>
        <h1 class="danger-title">Došlo je do greške</h1>
        <p class="page-description">Zahtjev nije bilo moguće obraditi.</p>
    </div>
</header>

<section class="panel">
    @if (Model.ShowRequestId)
    {
        <p>
            <strong>ID zahtjeva:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <p class="muted-text">
        Tijekom razvoja možete uključiti razvojno okruženje kako biste vidjeli detaljnije informacije o grešci.
    </p>
</section>
