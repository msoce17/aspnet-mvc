@model IEnumerable<SustavZaOrganizacijuNogometnihTurnira.Model.Turnir>

@{
    ViewData["Title"] = "Turniri";
}

@await Html.PartialAsync("_Breadcrumbs", new[]
{
    new BreadcrumbItem { Text = "Početna", Controller = "Home", Action = "Index" },
    new BreadcrumbItem { Text = "Turniri", IsActive = true }
})

<header class="page-header">
    <div>
        <p class="page-kicker">Natjecanja</p>
        <h1>Turniri</h1>
        <p class="page-description">Popis svih turnira u sustavu.</p>
    </div>
</header>

@if (!Model.Any())
{
    <p class="empty-state">Trenutno nema evidentiranih turnira.</p>
}
else
{
<div class="table-shell">
    <table class="data-table">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Tip</th>
                <th>Početak</th>
                <th>Završetak</th>
                <th>Max ekipa</th>
                <th class="table-actions">Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var turnir in Model)
            {
                <tr>
                    <td>
                        <a asp-controller="Turnir" asp-action="Details" asp-route-id="@turnir.TurnirId">
                            @turnir.Naziv
                        </a>
                    </td>
                    <td>@turnir.Tip</td>
                    <td>@turnir.DatumPocetka.ToString("dd.MM.yyyy.")</td>
                    <td>@turnir.DatumZavrsetka.ToString("dd.MM.yyyy.")</td>
                    <td>@turnir.MaximalanBrojEkipa</td>
                    <td class="table-actions">
                        <a class="action-link" asp-controller="Turnir" asp-action="Details" asp-route-id="@turnir.TurnirId">
                            Detalji
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}
